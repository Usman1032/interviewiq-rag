# Copy this file to .env and fill in the values

# Anthropic API key used for question generation and summary insights.
# If left empty, the system falls back to a deterministic template-based
# generator so the pipeline still runs end-to-end for local demos.
ANTHROPIC_API_KEY=

# SQLite by default; swap for a Postgres URL in production
DATABASE_URL=sqlite:///./storage/app.db

# Where the persistent Chroma vector store is written
VECTOR_STORE_DIR=./storage/vector_store

# Embedding model (runs locally via sentence-transformers, no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Root folder containing one subfolder of source docs per role
KNOWLEDGE_BASE_DIR=./app/knowledge_base

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# How many chunks to retrieve per query
TOP_K=4

# How many questions make up one interview session
QUESTIONS_PER_SESSION=6
